table Reports

	column OwnerTenantGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerTenantGuid

	column OwnerUserGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerUserGuid

	column OwnerGroupGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerGroupGuid

	column ReportGuid
		dataType: string
		sourceProviderType: varchar(36)
		sourceColumn: ReportGuid

	column DisplayName
		dataType: string
		sourceProviderType: nvarchar
		sourceColumn: DisplayName

	partition Usage_Reports_V2 = query
		dataView: full
		source
			query =
				SELECT [Viewers].[Usage_Reports_V2].*
				FROM [Viewers].[Usage_Reports_V2]
				WHERE [Viewers].[Usage_Reports_V2].[OwnerTenantGuid] = '2dff09ac-2b3b-4182-9953-2b548e0d0b39' AND ([Viewers].[Usage_Reports_V2].[OwnerGroupGuid] = '4680fd46-49c4-4cd4-8661-8e852e202558' OR [Viewers].[Usage_Reports_V2].[OwnerUserGuid] = '')
			dataSource: bd7c0be5-4f36-44e9-bc91-20679d41615b

