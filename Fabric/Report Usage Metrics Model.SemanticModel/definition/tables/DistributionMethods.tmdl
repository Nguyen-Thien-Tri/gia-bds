table DistributionMethods

	column OwnerTenantGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerTenantGuid

	column OwnerUserGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerUserGuid

	column OwnerGroupGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerGroupGuid

	column Name
		dataType: string
		sourceProviderType: nvarchar
		sourceColumn: Name

	partition Usage_ReportDistributionMethods = query
		dataView: full
		source
			query =
				SELECT [Viewers].[Usage_ReportDistributionMethods].*
				FROM [Viewers].[Usage_ReportDistributionMethods]
				WHERE [Viewers].[Usage_ReportDistributionMethods].[OwnerTenantGuid] IS NULL OR ([Viewers].[Usage_ReportDistributionMethods].[OwnerTenantGuid] = '2dff09ac-2b3b-4182-9953-2b548e0d0b39' AND ([Viewers].[Usage_ReportDistributionMethods].[OwnerGroupGuid] = '4680fd46-49c4-4cd4-8661-8e852e202558' OR [Viewers].[Usage_ReportDistributionMethods].[OwnerUserGuid] = ''))
			dataSource: bd7c0be5-4f36-44e9-bc91-20679d41615b

