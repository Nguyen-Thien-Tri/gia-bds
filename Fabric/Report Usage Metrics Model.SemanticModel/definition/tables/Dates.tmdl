table Dates
	dataCategory: Time

	column Date
		dataType: dateTime
		formatString: yyyy-MM-dd
		sourceProviderType: date
		sourceColumn: FullDate

		annotation Format = <Format Format="DateTimeCustom"><DateTimes><DateTime LCID="1033" Group="ShortDate" FormatString="yyyy-MM-dd" /></DateTimes></Format>

	column Month
		dataType: int64
		formatString: 0
		sourceProviderType: int
		sourceColumn: Month

	column Day
		dataType: int64
		formatString: 0
		sourceProviderType: int
		sourceColumn: Day

	column OwnerTenantGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerTenantGuid

	column OwnerUserGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerUserGuid

	column OwnerGroupGuid
		dataType: string
		isHidden
		sourceProviderType: varchar(36)
		sourceColumn: OwnerGroupGuid

	partition Usage_ReportDates_V1 = query
		dataView: full
		source
			query =
				SELECT [Viewers].[Usage_ReportDates_V1].*
				FROM [Viewers].[Usage_ReportDates_V1]
				WHERE [Viewers].[Usage_ReportDates_V1].[OwnerTenantGuid] = '2dff09ac-2b3b-4182-9953-2b548e0d0b39' AND ([Viewers].[Usage_ReportDates_V1].[OwnerGroupGuid] = '4680fd46-49c4-4cd4-8661-8e852e202558' OR [Viewers].[Usage_ReportDates_V1].[OwnerUserGuid] = '')
			dataSource: bd7c0be5-4f36-44e9-bc91-20679d41615b

