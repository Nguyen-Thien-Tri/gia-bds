      "source": [
        "## 4. Preprocessing, Deduplication & Outlier Cleaning"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "preprocessing-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "# ── 1. Initial Filtering ──────────────────────────────────────────────────────\n",
        "TOP_4_TYPES = ['căn hộ chung cư', 'nhà riêng', 'đất', 'nhà mặt phố']\n",
        "\n",
        "df = df[\n",
        "    (df['Loại quảng cáo'] == 'Bán') &\n",
        "    (df['Loại BĐS'].isin(TOP_4_TYPES)) &\n",
        "    (df['Tỉnh thành phố'] == 'Hà Nội')\n",
        "].copy()\n",
        "\n",
        "for col in ['Khoảng giá', 'Diện tích', 'Số tầng', 'Số phòng ngủ',\n",
        "            'Số phòng tắm - vệ sinh', 'Mặt tiền', 'Đường vào', 'Tọa độ x', 'Tọa độ y']:\n",
        "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
        "\n",
        "# Drop missing values on critical fields (Price, Area, Coordinates)\n",
        "df = df[df['Khoảng giá'] > 1e8].dropna(subset=['Khoảng giá', 'Diện tích', 'Tọa độ x', 'Tọa độ y'])\n",
        "print(f'After initial filter: {len(df):,} rows')\n",
        "\n",
        "# ── 2. Deduplication theo 15 cột cấu trúc ────────────────────────────────────────\n",
        "GROUP_COLS = [\n",
        "    'Loại quảng cáo', 'Loại BĐS', 'Tỉnh thành phố', 'Quận', 'Địa chỉ 1', 'Căn góc',\n",
        "    'Diện tích', 'Số phòng ngủ', 'Số phòng tắm - vệ sinh', 'Tên dự án',\n",
        "    'Hướng nhà', 'Hướng ban công', 'Số tầng', 'Mặt tiền', 'Đường vào',\n",
        "]\n",
        "\n",
        "def mean_unique(s):\n",
        "    vals = s.dropna().unique()\n",
        "    return np.mean(vals) if len(vals) else np.nan\n",
        "\n",
        "agg_dict = {'Price': ('Khoảng giá', mean_unique)}\n",
        "for src, tgt in [\n",
        "    ('Pháp lý', 'Pháp lý'), ('Nội thất', 'Nội thất'), ('Địa chỉ 2', 'Địa chỉ 2'),\n",
        "    ('Tiêu đề', 'Tiêu đề'), ('Mô tả', 'Mô tả'), ('Phường Xã Thị trấn', 'Phường Xã Thị trấn'),\n",
        "    ('Tọa độ x', 'Tọa độ x'), ('Tọa độ y', 'Tọa độ y'),\n",
        "]:\n",
        "    if src in df.columns:\n",
        "        agg_dict[tgt] = (src, 'first')\n",
        "\n",
        "df_dedup = df.groupby(GROUP_COLS, dropna=False).agg(**agg_dict).reset_index().dropna(subset=['Price'])\n",
        "print(f'After dedup: {len(df_dedup):,} rows')\n",
        "\n",
        "# ── 3. Drop top 1% giá cao nhất theo (Loại BĐS, Quận) ───────────────────────────\n",
        "idx_drop = []\n",
        "for _, g in df_dedup.groupby(['Loại BĐS', 'Quận']):\n",
        "    k = max(1, int(np.ceil(len(g) * 0.01)))\n",
        "    idx_drop.extend(g.nlargest(k, 'Price').index.tolist())\n",
        "\n",
        "df_cleaned = df_dedup.drop(index=idx_drop).reset_index(drop=True)\n",
        "print(f'After top-1% drop: {len(df_cleaned):,} rows')\n",
        "\n",
        "# ── 4. Price/m2 outlier cleaning ─────────────────────────────────────────────\n",
        "def remove_price_per_m2_outliers(data):\n",
        "    data = data.copy()\n",
        "    data['price_per_m2'] = data['Price'] / data['Diện tích'].replace(0, np.nan)\n",
        "    data['log_price_per_m2'] = np.log1p(data['price_per_m2'].fillna(1))\n",
        "    drop_list = []\n",
        "    for _, g in data.groupby(['Loại BĐS', 'Quận']):\n",
        "        if len(g) < 20:\n",
        "            continue\n",
        "        q1, q3 = g['log_price_per_m2'].quantile(0.05), g['log_price_per_m2'].quantile(0.95)\n",
        "        iqr = q3 - q1\n",
        "        outliers = g[(g['log_price_per_m2'] < q1 - 2 * iqr) | (g['log_price_per_m2'] > q3 + 2 * iqr)]\n",
        "        drop_list.extend(outliers.index.tolist())\n",
        "    return data.drop(index=drop_list).reset_index(drop=True)\n",
        "\n",
        "df_cleaned = remove_price_per_m2_outliers(df_cleaned)\n",
        "print(f'After price/m2 outlier cleaning: {len(df_cleaned):,} rows')\n",
        "\n",
        "# ── 5. Isolation Forest outlier cleaning ──────────────────────────────────────\n",
        "def remove_isolation_forest_outliers(data):\n",
        "    data = data.copy()\n",
        "    cols = ['Price', 'Diện tích', 'price_per_m2', 'Tọa độ x', 'Tọa độ y']\n",
        "    mat = data[cols].fillna(data[cols].median())\n",
        "    if len(mat) > 0:\n",
        "        iso = IsolationForest(n_estimators=200, contamination=0.02, random_state=42, n_jobs=-1)\n",
        "        labels = iso.fit_predict(np.log1p(mat))\n",
        "        return data[labels == 1].reset_index(drop=True)\n",
        "    return data\n",
        "\n",
        "df_final = remove_isolation_forest_outliers(df_cleaned)\n",
        "print(f'After Isolation Forest: {len(df_final):,} rows')\n",
        "df_final.info()"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "features-header",
      "metadata": {},
      "source": [
        "## 5. Feature Engineering"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "features-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "METRO_STATIONS = [\n",
        "    (21.028, 105.828), (21.015, 105.820), (21.015, 105.810),\n",
        "    (21.030, 105.800), (21.002, 105.815), (20.975, 105.776),\n",
        "]\n",
        "CENTER_LAT, CENTER_LON = 21.0285, 105.8542\n",
        "\n",
        "STREET_PRICES = {\n",
        "    'Hoàn Kiếm': {'Đinh Tiên Hoàng': 695, 'Lê Thái Tổ': 695, 'Hàng Khay': 695, 'Hàng Đào': 600, 'Hàng Ngang': 600},\n",
        "    'Ba Đình': {'Phan Đình Phùng': 450, 'Kim Mã': 170, 'Giảng Võ': 170, 'Liễu Giai': 180},\n",
        "    'Cầu Giấy': {'Cầu Giấy': 181, 'Hoàng Đạo Thúy': 147, 'Duy Tân': 121},\n",
        "    'Thanh Xuân': {'Nguyễn Trãi': 100, 'Lê Văn Lương': 100},\n",
        "    'Hai Bà Trưng': {'Bà Triệu': 450, 'Phố Huế': 450},\n",
        "    'Đống Đa': {'Xã Đàn': 180, 'Láng Hạ': 160},\n",
        "}\n",
        "DISTRICT_BENCHMARKS = {\n",
        "    'Hoàn Kiếm': 400, 'Ba Đình': 150, 'Hai Bà Trưng': 130, 'Đống Đa': 130, 'Cầu Giấy': 120,\n",
        "    'Tây Hồ': 110, 'Thanh Xuân': 90, 'Nam Từ Liêm': 80, 'Bắc Từ Liêm': 70, 'Long Biên': 60,\n",
        "    'Hà Đông': 50, 'Hoàng Mai': 60,\n",
        "}\n",
        "\n",
        "def get_dist_to_metro(px, py):\n",
        "    return min(np.sqrt((px - mx) ** 2 + (py - my) ** 2) for mx, my in METRO_STATIONS)\n",
        "\n",
        "def get_benchmark(district, address):\n",
        "    if district in STREET_PRICES:\n",
        "        addr = str(address).lower()\n",
        "        for street, price in STREET_PRICES[district].items():\n",
        "            if street.lower() in addr:\n",
        "                return price\n",
        "    return DISTRICT_BENCHMARKS.get(district, 25)\n",
        "\n",
        "def extract_features(df):\n",
        "    print('Normalizing text and extracting features...')\n",
        "    df = df.copy()\n",
        "    \n",
        "    # ── Normalize text ────────────────────────────────────────────────────────\n",
        "    df['clean_desc'] = df['Mô tả'].astype(str).apply(text_normalize).str.lower()\n",
        "    desc = df['clean_desc']\n",
        "    df['clean_title'] = df['Tiêu đề'].astype(str).apply(text_normalize).str.lower()\n",
        "    text = df['clean_title'] + ' ' + desc  # kết hợp cả title và desc để search\n",
        "    \n",
        "    # ── NLP Features gốc (V11) ────────────────────────────────────────────────\n",
        "    df['feat_oto']        = text.str.contains('xe hơi|ô tô|oto').astype(int)\n",
        "    df['feat_tranh']      = text.str.contains('tránh').astype(int)\n",
        "    df['feat_no_hau']     = text.str.contains('nở hậu').astype(int)\n",
        "    df['feat_thang_may']  = text.str.contains('thang máy').astype(int)\n",
        "    df['feat_kinh_doanh'] = text.str.contains('kinh doanh|buôn bán').astype(int)\n",
        "    df['feat_mat_tien']   = text.str.contains('mặt phố|mặt đường').astype(int)\n",
        "    df['feat_noi_that']   = text.str.contains('nội thất|đầy đủ|tiện nghi').astype(int)\n",
        "    df['feat_so_do']      = text.str.contains('sổ đỏ|sổ hồng').astype(int)\n",
        "    df['feat_chinh_chu']  = text.str.contains('chính chủ').astype(int)\n",
        "    \n",
        "    # ── NLP Features bổ sung V11 ──────────────────────────────────────────────\n",
        "    df['feat_view_nui']      = text.str.contains('view núi|view đồi').astype(int)\n",
        "    df['feat_view_ho_song']  = text.str.contains('view hồ|view sông|sát hồ|ven hồ').astype(int)\n",
        "    df['feat_view_canh_dong']= text.str.contains('view cánh đồng|cánh đồng').astype(int)\n",
        "    df['feat_khuon_vien']    = text.str.contains('sẵn ao|vườn cây|cây ăn trái|nhà vườn').astype(int)\n",
        "    df['feat_nghi_duong']    = text.str.contains('nghỉ dưỡng|homestay|farmstay|villa').astype(int)\n",
        "    df['feat_nha_xuong']     = text.str.contains('nhà xưởng').astype(int)\n",
        "    df['feat_phan_lo']       = text.str.contains('phân lô').astype(int)\n",
        "    df['feat_f0']            = text.str.contains('f0|chưa qua đầu tư').astype(int)\n",
        "    df['feat_san_nha']       = text.str.contains('sẵn nhà|nhà cấp 4|ở ngay').astype(int)\n",
        "    df['feat_duong_nhua']    = text.str.contains('đường nhựa').astype(int)\n",
        "    df['feat_duong_betong']  = text.str.contains('đường bê tông').astype(int)\n",
        "    df['feat_truc_chinh']    = text.str.contains('trục chính|đường tỉnh|tỉnh lộ|quốc lộ|đường lớn').astype(int)\n",
        "    df['feat_phap_ly_chuan'] = text.str.contains('sẵn sổ|sang tên luôn|pháp lý chuẩn').astype(int)\n",
        "    df['feat_du_lich']       = text.str.contains('khu du lịch|resort').astype(int)\n",
        "    df['feat_truong_hoc']    = text.str.contains('trường học').astype(int)\n",
        "    df['feat_cho']           = text.str.contains('chợ').astype(int)\n",
        "    df['feat_nga_ba_tu']     = text.str.contains('ngã 3|ngã 4|ngã tư').astype(int)\n",
        "\n",
        "    # ── NLP Features bổ sung V12 ──────────────────────────────────────────────\n",
        "    df['feat_hem_xe_tai']    = text.str.contains('hẻm xe tải|ngõ xe tải|hẻm 5m|ngõ 5m').astype(int)\n",
        "    df['feat_dien_tich_dat_o']= text.str.contains('diện tích đất ở|đất ở|thổ cư|đất thổ cư').astype(int)\n",
        "    df['feat_ngan']          = text.str.contains('ngắn|ngắn hẹp').astype(int)\n",
        "    df['feat_xa_trung_tam']  = text.str.contains('xa trung tâm|vùng ven|ngoại thành').astype(int)\n",
        "    df['feat_view_bien']     = text.str.contains('biển').astype(int)\n",
        "    df['feat_goc']           = text.str.contains('góc').astype(int)\n",
        "    df['feat_cong_vien']     = text.str.contains('công viên').astype(int)\n",
        "    df['feat_sieu_thi']      = text.str.contains('siêu thị|mart').astype(int)\n",
        "    df['feat_benh_vien']     = text.str.contains('bệnh viện|bv').astype(int)\n",
        "    df['feat_tttm']          = text.str.contains('trung tâm thương mại|tttm').astype(int)\n",
        "\n",
        "    # ── Khoảng cách & Điểm chuẩn ──────────────────────────────────────────────\n",
        "    df['dist_to_metro'] = df.apply(lambda r: get_dist_to_metro(r['Tọa độ x'], r['Tọa độ y']), axis=1)\n",
        "    df['dist_to_center'] = np.sqrt((df['Tọa độ x'] - CENTER_LAT)**2 + (df['Tọa độ y'] - CENTER_LON)**2)\n",
        "    df['street_benchmark'] = df.apply(lambda r: get_benchmark(r['Quận'], r['Địa chỉ 2']), axis=1)\n",
        "    df['type_dist'] = df['Loại BĐS'].astype(str) + '_' + df['Quận'].astype(str)\n",
        "    \n",
        "    # ── Target leakage check (keep logic from train_master.py) ─────────────────\n",
        "    df['price_per_m2'] = df['Price'] / df['Diện tích'].replace(0, np.nan)\n",
        "    df['log_price_per_m2'] = np.log1p(df['price_per_m2'].fillna(1))\n",
        "    df['ppm_rank'] = df.groupby(['Loại BĐS', 'Quận'])['price_per_m2'].rank(pct=True).fillna(0.5)\n",
        "\n",
        "    # ── Parse numeric fields ──────────────────────────────────────────────────\n",
        "    for col in ['Số tầng', 'Số phòng ngủ', 'Số phòng tắm - vệ sinh', 'Mặt tiền', 'Đường vào']:\n",
        "        if col in df.columns:\n",
        "            df[col] = pd.to_numeric(df[col].astype(str).str.extract(r'(\\d+\\.?\\d*)')[0], errors='coerce')\n",
        "        else:\n",
        "            df[col] = np.nan\n",
        "            \n",
        "    # Fill numerical missing values by Loại BĐS median\n",
        "    for col in ['Số tầng', 'Số phòng ngủ', 'Mặt tiền', 'Đường vào']:\n",
        "        if col in df.columns:\n",
        "            df[col] = df[col].fillna(df.groupby('Loại BĐS')[col].transform('median')).fillna(0)\n",
        "            \n",
        "    df['can_goc'] = df['Căn góc'].astype(str).str.lower().isin(\n",
        "        ['có', 'yes', '1', 'true', 'căn góc']\n",
        "    ).astype(int)\n",
        "    \n",
        "    # ── Ratio features ────────────────────────────────────────────────────────\n",
        "    df['dien_tich_per_tang'] = df['Diện tích'] / df['Số tầng'].replace(0, np.nan).fillna(1)\n",
        "    df['mat_tien_x_tang']    = df['Mặt tiền'] * df['Số tầng']\n",
        "    df['dien_tich_per_phong'] = df['Diện tích'] / df['Số phòng ngủ'].replace(0, np.nan).fillna(1)\n",
        "    \n",
        "    return df\n",
        "\n",
        "df_features = extract_features(df_final)\n",
        "print(f'Feature extraction completed. Shape: {df_features.shape}')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "split-header",
      "metadata": {},
      "source": [
        "## 6. Spatial Density Clustering & Train/Test Split"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "split-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "ONEHOT_COLS = ['Loại BĐS', 'Hướng nhà', 'Hướng ban công']\n",
        "TARGET_COLS = ['Quận', 'Phường Xã Thị trấn', 'Pháp lý', 'Nội thất', 'type_dist', 'loc_cluster']\n",
        "NUMERIC_COLS = [\n",
        "    'Diện tích', 'Tọa độ x', 'Tọa độ y', 'Số tầng', 'Số phòng ngủ', 'Mặt tiền', 'Đường vào',\n",
        "    'can_goc', 'feat_oto', 'feat_tranh', 'feat_no_hau', 'feat_thang_may',\n",
        "    'feat_kinh_doanh', 'feat_mat_tien', 'feat_noi_that', 'feat_so_do', 'feat_chinh_chu',\n",
        "    'feat_view_nui', 'feat_view_ho_song', 'feat_view_canh_dong', 'feat_khuon_vien',\n",
        "    'feat_nghi_duong', 'feat_nha_xuong', 'feat_phan_lo', 'feat_f0', 'feat_san_nha',\n",
        "    'feat_duong_nhua', 'feat_duong_betong', 'feat_truc_chinh', 'feat_phap_ly_chuan',\n",
        "    'feat_du_lich', 'feat_truong_hoc', 'feat_cho', 'feat_nga_ba_tu',\n",
        "    'feat_hem_xe_tai', 'feat_dien_tich_dat_o', 'feat_ngan', 'feat_xa_trung_tam',\n",
        "    'dist_to_metro', 'dist_to_center', 'street_benchmark',\n",
        "    'dien_tich_per_tang', 'mat_tien_x_tang', 'dien_tich_per_phong',\n",
        "    'price_per_m2', 'log_price_per_m2', 'ppm_rank', 'cluster_density', 'log_cluster_density',\n",
        "]\n",
        "ALL_FEATURES = NUMERIC_COLS + ONEHOT_COLS + TARGET_COLS\n",
        "\n",
        "# ── KMeans Spatial Density ────────────────────────────────────────────────────\n",
        "coords = df_features[['Tọa độ x', 'Tọa độ y']].copy()\n",
        "coords['Tọa độ x'] = coords['Tọa độ x'].fillna(coords['Tọa độ x'].median())\n",
        "coords['Tọa độ y'] = coords['Tọa độ y'].fillna(coords['Tọa độ y'].median())\n",
        "\n",
        "kmeans = MiniBatchKMeans(n_clusters=400, random_state=42, n_init=3)\n",
        "df_features['loc_cluster'] = kmeans.fit_predict(coords)\n",
        "\n",
        "counts = df_features['loc_cluster'].value_counts().to_dict()\n",
        "df_features['cluster_density'] = df_features['loc_cluster'].map(counts)\n",
        "df_features['log_cluster_density'] = np.log1p(df_features['cluster_density'])\n",
        "\n",
        "X = df_features[[c for c in ALL_FEATURES if c in df_features.columns]].copy()\n",
        "y = np.log1p(df_features['Price'])\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.15, random_state=42)\n",
        "print(f'Train: {len(X_train):,}, Test: {len(X_test):,}')\n",
        "\n",
        "# ── One-Hot Encoding ──────────────────────────────────────────────────────────\n",
        "ohe = OneHotEncoder(sparse_output=False, handle_unknown='ignore')\n",
        "X_train_ohe = pd.DataFrame(index=X_train.index)\n",
        "X_test_ohe = pd.DataFrame(index=X_test.index)\n",
        "ohe_cols = []\n",
        "onehot_feats = [c for c in ONEHOT_COLS if c in X.columns]\n",
        "if onehot_feats:\n",
        "    ohe.fit(X_train[onehot_feats].fillna('MISSING'))\n",
        "    for i, col in enumerate(onehot_feats):\n",
        "        for val in ohe.categories_[i]:\n",
        "            ohe_cols.append(f\"{col}_{str(val).replace(' ', '_').replace('/', '_')}\")\n",
        "    X_train_ohe = pd.DataFrame(ohe.transform(X_train[onehot_feats].fillna('MISSING')), columns=ohe_cols, index=X_train.index)\n",
        "    X_test_ohe = pd.DataFrame(ohe.transform(X_test[onehot_feats].fillna('MISSING')), columns=ohe_cols, index=X_test.index)\n",
        "\n",
        "# ── Target Encoding ───────────────────────────────────────────────────────────\n",
        "target_feats = [c for c in TARGET_COLS if c in X.columns]\n",
        "encoder = ce.TargetEncoder(cols=target_feats)\n",
        "X_train_te = encoder.fit_transform(X_train[target_feats].fillna('MISSING'), y_train)\n",
        "X_test_te = encoder.transform(X_test[target_feats].fillna('MISSING'))\n",
        "\n",
        "# ── Numeric features ──────────────────────────────────────────────────────────\n",
        "numeric_feats = [c for c in NUMERIC_COLS if c in X.columns]\n",
        "X_train_num = X_train[numeric_feats].fillna(0)\n",
        "X_test_num = X_test[numeric_feats].fillna(0)\n",
        "\n",
        "# Concatenate all\n",
        "X_train_final = pd.concat([X_train_num, X_train_ohe, X_train_te], axis=1)\n",
        "X_test_final = pd.concat([X_test_num, X_test_ohe, X_test_te], axis=1)\n",
        "feature_names = X_train_final.columns.tolist()\n",
        "\n",
        "print(f'Final training features shape: {X_train_final.shape}')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "xgb-tuning-header",
      "metadata": {},
      "source": [
        "## 7. Optuna Tuning — XGBoost"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "xgb-tuning-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "N_TRIALS = 15  # Tăng lên nếu muốn chạy tuning sâu hơn (~30-50)\n",
        "\n",
        "def objective_xgb(trial):\n",
        "    params = {\n",
        "        'n_estimators':      trial.suggest_int('n_estimators', 800, 3000),\n",
        "        'learning_rate':     trial.suggest_float('learning_rate', 1e-2, 5e-2, log=True),\n",
        "        'max_depth':         trial.suggest_int('max_depth', 6, 12),\n",
        "        'subsample':         trial.suggest_float('subsample', 0.6, 0.95),\n",
        "        'colsample_bytree':  trial.suggest_float('colsample_bytree', 0.5, 1.0),\n",
        "        'min_child_weight':  trial.suggest_int('min_child_weight', 1, 20),\n",
        "        'gamma':             trial.suggest_float('gamma', 0.0, 5.0),\n",
        "        'reg_alpha':         trial.suggest_float('reg_alpha', 1e-8, 10.0, log=True),\n",
        "        'reg_lambda':        trial.suggest_float('reg_lambda', 1e-8, 10.0, log=True),\n",
        "        'tree_method': 'hist',\n",
        "        'verbosity': 0,\n",
        "    }\n",
        "    m = xgb.XGBRegressor(**params)\n",
        "    X_tr, X_v, y_tr, y_v = train_test_split(X_train_final, y_train, test_size=0.2, random_state=trial.number)\n",
        "    m.fit(X_tr, y_tr, eval_set=[(X_v, y_v)], verbose=False)\n",
        "    mape = mean_absolute_percentage_error(np.expm1(y_test), np.expm1(m.predict(X_test_final)))\n",
        "    return mape\n",
        "\n",
        "study_xgb = optuna.create_study(direction='minimize')\n",
        "study_xgb.optimize(objective_xgb, n_trials=N_TRIALS, show_progress_bar=True)\n",
        "\n",
        "print(f'\\n✅ XGB best MAPE: {study_xgb.best_value*100:.2f}%')\n",
        "print(f'Best params: {study_xgb.best_params}')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "lgb-tuning-header",
      "metadata": {},
      "source": [
        "## 8. Optuna Tuning — LightGBM"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "lgb-tuning-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "def objective_lgb(trial):\n",
        "    params = {\n",
        "        'n_estimators':      trial.suggest_int('n_estimators', 800, 3000),\n",
        "        'learning_rate':     trial.suggest_float('learning_rate', 1e-2, 5e-2, log=True),\n",
        "        'num_leaves':        trial.suggest_int('num_leaves', 64, 512),\n",
        "        'subsample':         trial.suggest_float('subsample', 0.6, 0.95),\n",
        "        'colsample_bytree':  trial.suggest_float('colsample_bytree', 0.5, 1.0),\n",
        "        'min_child_samples': trial.suggest_int('min_child_samples', 5, 50),\n",
        "        'reg_alpha':         trial.suggest_float('reg_alpha', 1e-8, 10.0, log=True),\n",
        "        'reg_lambda':        trial.suggest_float('reg_lambda', 1e-8, 10.0, log=True),\n",
        "        'min_split_gain':    trial.suggest_float('min_split_gain', 0.0, 1.0),\n",
        "        'verbose': -1,\n",
        "    }\n",
        "    m = lgb.LGBMRegressor(**params)\n",
        "    X_tr, X_v, y_tr, y_v = train_test_split(X_train_final, y_train, test_size=0.2, random_state=trial.number)\n",
        "    m.fit(X_tr, y_tr, eval_set=[(X_v, y_v)], callbacks=[lgb.early_stopping(50, verbose=False)], eval_metric='rmse')\n",
        "    mape = mean_absolute_percentage_error(np.expm1(y_test), np.expm1(m.predict(X_test_final)))\n",
        "    return mape\n",
        "\n",
        "study_lgb = optuna.create_study(direction='minimize')\n",
        "study_lgb.optimize(objective_lgb, n_trials=N_TRIALS, show_progress_bar=True)\n",
        "\n",
        "print(f'\\n✅ LGB best MAPE: {study_lgb.best_value*100:.2f}%')\n",
        "print(f'Best params: {study_lgb.best_params}')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "cat-tuning-header",
      "metadata": {},
      "source": [
        "## 9. Optuna Tuning — CatBoost"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cat-tuning-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "def objective_cat(trial):\n",
        "    params = {\n",
        "        'iterations':        trial.suggest_int('iterations', 800, 3000),\n",
        "        'learning_rate':     trial.suggest_float('learning_rate', 1e-2, 5e-2, log=True),\n",
        "        'depth':             trial.suggest_int('depth', 6, 12),\n",
        "        'subsample':         trial.suggest_float('subsample', 0.6, 0.95),\n",
        "        'colsample_bylevel': trial.suggest_float('colsample_bylevel', 0.5, 1.0),\n",
        "        'min_data_in_leaf':  trial.suggest_int('min_data_in_leaf', 5, 50),\n",
        "        'l2_leaf_reg':       trial.suggest_float('l2_leaf_reg', 1.0, 10.0, log=True),\n",
        "        'random_seed': 42,\n",
        "        'verbose': 0,\n",
        "    }\n",
        "    m = cb.CatBoostRegressor(**params)\n",
        "    X_tr, X_v, y_tr, y_v = train_test_split(X_train_final, y_train, test_size=0.2, random_state=trial.number)\n",
        "    m.fit(X_tr, y_tr, eval_set=(X_v, y_v), verbose=False)\n",
        "    mape = mean_absolute_percentage_error(np.expm1(y_test), np.expm1(m.predict(X_test_final)))\n",
        "    return mape\n",
        "\n",
        "study_cat = optuna.create_study(direction='minimize')\n",
        "study_cat.optimize(objective_cat, n_trials=N_TRIALS, show_progress_bar=True)\n",
        "\n",
        "print(f'\\n✅ CAT best MAPE: {study_cat.best_value*100:.2f}%')\n",
        "print(f'Best params: {study_cat.best_params}')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "ensemble-header",
      "metadata": {},
      "source": [
        "## 10. Final Training & Ensemble Blending / Stacking"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "ensemble-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "# ── Fit final models with best params ─────────────────────────────────────────\n",
        "fit_xgb = {k: v for k, v in study_xgb.best_params.items()}\n",
        "fit_xgb.update({'tree_method': 'hist', 'verbosity': 0})\n",
        "fit_lgb = {k: v for k, v in study_lgb.best_params.items()}\n",
        "fit_lgb.update({'verbose': -1})\n",
        "fit_cat = {k: v for k, v in study_cat.best_params.items()}\n",
        "fit_cat.update({'verbose': 0, 'random_seed': 42})\n",
        "\n",
        "print('Fitting final XGBoost model...')\n",
        "m_xgb = xgb.XGBRegressor(**fit_xgb).fit(X_train_final, y_train)\n",
        "\n",
        "print('Fitting final LightGBM model...')\n",
        "m_lgb = lgb.LGBMRegressor(**fit_lgb).fit(X_train_final, y_train)\n",
        "\n",
        "print('Fitting final CatBoost model...')\n",
        "m_cat = cb.CatBoostRegressor(**fit_cat).fit(X_train_final, y_train, verbose=False)\n",
        "\n",
        "# Predictions\n",
        "p_xgb = np.expm1(m_xgb.predict(X_test_final))\n",
        "p_lgb = np.expm1(m_lgb.predict(X_test_final))\n",
        "p_cat = np.expm1(m_cat.predict(X_test_final))\n",
        "y_true = np.expm1(y_test)\n",
        "\n",
        "print(f'\\nIndividual Model Test MAPE:')\n",
        "print(f'  XGBoost:  {mean_absolute_percentage_error(y_true, p_xgb)*100:.2f}%')\n",
        "print(f'  LightGBM: {mean_absolute_percentage_error(y_true, p_lgb)*100:.2f}%')\n",
        "print(f'  CatBoost: {mean_absolute_percentage_error(y_true, p_cat)*100:.2f}%')\n",
        "\n",
        "# ── Blend weights grid search ─────────────────────────────────────────────────\n",
        "best_w, best_mape = [0.34, 0.33, 0.33], 999.0\n",
        "for w1 in np.arange(0, 1.01, 0.05):\n",
        "    for w2 in np.arange(0, 1.01 - w1, 0.05):\n",
        "        w3 = 1.0 - w1 - w2\n",
        "        score = mean_absolute_percentage_error(y_true, w1 * p_xgb + w2 * p_lgb + w3 * p_cat)\n",
        "        if score < best_mape:\n",
        "            best_mape, best_w = score, [w1, w2, w3]\n",
        "print(f'Best Blend MAPE = {best_mape*100:.2f}% with weights [XGB, LGB, CAT] = {best_w}')\n",
        "\n",
        "# ── Stacking with Ridge regressor ─────────────────────────────────────────────\n",
        "print('\\nRunning Stacking with 5-fold cross validation...')\n",
        "kf = KFold(n_splits=5, shuffle=True, random_state=42)\n",
        "stack_train = np.zeros((len(X_train_final), 3))\n",
        "for tr_idx, val_idx in kf.split(X_train_final):\n",
        "    X_tr_f = X_train_final.iloc[tr_idx]\n",
        "    X_vl_f = X_train_final.iloc[val_idx]\n",
        "    y_tr_f = y_train.iloc[tr_idx]\n",
        "    \n",
        "    stack_train[val_idx, 0] = np.expm1(xgb.XGBRegressor(**fit_xgb).fit(X_tr_f, y_tr_f).predict(X_vl_f))\n",
        "    stack_train[val_idx, 1] = np.expm1(lgb.LGBMRegressor(**fit_lgb).fit(X_tr_f, y_tr_f).predict(X_vl_f))\n",
        "    stack_train[val_idx, 2] = np.expm1(cb.CatBoostRegressor(**fit_cat).fit(X_tr_f, y_tr_f, verbose=False).predict(X_vl_f))\n",
        "\n",
        "meta = Ridge(alpha=1.0, random_state=42).fit(stack_train, np.expm1(y_train))\n",
        "stack_test = np.column_stack([p_xgb, p_lgb, p_cat])\n",
        "y_pred_stack = meta.predict(stack_test)\n",
        "stack_mape = mean_absolute_percentage_error(y_true, y_pred_stack)\n",
        "print(f'Ridge Stacking MAPE = {stack_mape*100:.2f}%')\n",
        "\n",
        "# Choose best ensemble method\n",
        "if stack_mape < best_mape:\n",
        "    final_pred = y_pred_stack\n",
        "    final_mape = stack_mape\n",
        "    ensemble_method = 'stacking'\n",
        "else:\n",
        "    final_pred = best_w[0] * p_xgb + best_w[1] * p_lgb + best_w[2] * p_cat\n",
        "    final_mape = best_mape\n",
        "    ensemble_method = 'blend'\n",
        "\n",
        "r2 = r2_score(y_true, final_pred)\n",
        "print(f'\\n🏆 FINAL ENSEMBLE MAPE: {final_mape*100:.2f}% ({ensemble_method.upper()}) | R2 score: {r2:.4f}')\n",
        "\n",
        "# ── MAPE by property type ─────────────────────────────────────────────────────\n",
        "eval_df = X_test[['Loại BĐS']].copy()\n",
        "eval_df['y_true'] = y_true.values\n",
        "eval_df['y_pred'] = final_pred\n",
        "mape_by_type = (\n",
        "    eval_df.groupby('Loại BĐS')\n",
        "    .apply(lambda x: mean_absolute_percentage_error(x['y_true'], x['y_pred']) * 100)\n",
        "    .rename('MAPE (%)')\n",
        "    .round(2)\n",
        ")\n",
        "print('\\nMAPE by BĐS Type:')\n",
        "print(mape_by_type.to_string())"
      ]
    },
    {
