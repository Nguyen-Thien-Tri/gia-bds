        "# ── Cấu hình ──────────────────────────────────────────────────────────────────\n",
        "GCP_KEY_PATH  = '/lakehouse/default/Files/real-estate-project-445516-83dc50b692bc.json'\n",
        "BQ_TABLE      = 'real-estate-project-445516.real_estate_data.ads_data'\n",
