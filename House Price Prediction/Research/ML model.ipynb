        "joblib.dump(m_cat,   f'{LAKEHOUSE_DIR}/master_cat_final.joblib')\n",
        "joblib.dump(meta,    f'{LAKEHOUSE_DIR}/master_meta_final.joblib')\n",
        "joblib.dump(encoder, f'{LAKEHOUSE_DIR}/master_encoder_final.joblib')\n",
        "joblib.dump(kmeans,  f'{LAKEHOUSE_DIR}/master_kmeans_final.joblib')\n",
        "joblib.dump(ohe,     f'{LAKEHOUSE_DIR}/master_ohe_final.joblib')\n",
        "\n",
        "meta_info = {\n",
