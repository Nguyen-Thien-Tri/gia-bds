        "    'fit_xgb': {str(k): str(v) for k, v in fit_xgb.items()},\n",
        "    'fit_lgb': {str(k): str(v) for k, v in fit_lgb.items()},\n",
        "    'fit_cat': {str(k): str(v) for k, v in fit_cat.items()},\n",
        "    'feature_names': feature_names,\n",
        "    'n_train': len(X_train),\n",
        "    'n_test': len(X_test),\n",
        "}\n",
        "\n",
        "with open(f'{LAKEHOUSE_DIR}/model_meta_v12.json', 'w', encoding='utf-8') as f:\n",
        "    json.dump(meta_info, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "with open(f'{LAKEHOUSE_DIR}/model_meta_master.json', 'w', encoding='utf-8') as f:\n",
        "    json.dump(meta_info, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "print('✅ Models saved to Lakehouse directory successfully!')"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "eval-header",
      "metadata": {},
      "source": [
        "## 13. Evaluate on External HaNoiData"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "eval-code",
      "metadata": {
        "microsoft": {
          "language": "python",
          "language_group": "jupyter_python"
        }
      },
      "outputs": [],
      "source": [
        "print('Loading external HaNoiData for evaluation...')\n",
        "try:\n",
        "    X_ext = pd.read_csv(f'{LAKEHOUSE_DIR}/HaNoiXtestData.csv', encoding='utf-8')\n",
        "    y_ext = pd.read_csv(f'{LAKEHOUSE_DIR}/HaNoiYtestData.csv')\n",
        "except FileNotFoundError:\n",
        "    X_ext = pd.read_csv('HaNoiXtestData.csv', encoding='utf-8')\n",
        "    y_ext = pd.read_csv('HaNoiYtestData.csv')\n",
        "\n",
        "print(f'Loaded {len(X_ext):,} external samples')\n",
        "\n",
        "# ── Rename columns ───────────────────────────────────────────────────────────\n",
        "col_idx = X_ext.columns.tolist()\n",
        "rename_map = {}\n",
        "if len(col_idx) > 1: rename_map[col_idx[1]] = 'Loại BĐS'\n",
        "if len(col_idx) > 3: rename_map[col_idx[3]] = 'Quận'\n",
        "if len(col_idx) > 6: rename_map[col_idx[6]] = 'Diện tích'\n",
        "if len(col_idx) > 7: rename_map[col_idx[7]] = 'Số phòng ngủ'\n",
        "\n",
        "X_ext = X_ext.rename(columns={**rename_map,\n",
        "    'Phuong': 'Phường Xã Thị trấn', 'dia_chi_2': 'Địa chỉ 2',\n",
        "    'Mo_ta': 'Mô tả', 'Tieu_de': 'Tiêu đề', 'tieu_de': 'Tiêu đề',\n",
        "    'Toa_do_x': 'Tọa độ x', 'Toa_do_y': 'Tọa độ y',\n",
        "    'so_tang': 'Số tầng', 'mat_tien': 'Mặt tiền', 'duong_vao': 'Đường vào'\n",
        "})\n",
        "\n",
        "# ── Fill missing columns ─────────────────────────────────────────────────────\n",
        "for c in ['Địa chỉ 1', 'Căn góc', 'Hướng nhà', 'Hướng ban công', 'Pháp lý', 'Nội thất', \n",
        "          'Số phòng tắm - vệ sinh', 'Phường Xã Thị trấn']:\n",
        "    if c not in X_ext.columns:\n",
        "        X_ext[c] = np.nan\n",
        "\n",
        "for col in ['Diện tích', 'Tọa độ x', 'Tọa độ y']:\n",
        "    X_ext[col] = pd.to_numeric(X_ext[col], errors='coerce').fillna(0)\n",
        "\n",
        "# ── True prices ──────────────────────────────────────────────────────────────\n",
        "y_true_ext = y_ext['mean_unique_khoang_gia_million'] * 1e6\n",
        "\n",
        "# Gán Price để tính toán các đặc trưng giá m2 mà mô hình V12 yêu cầu (tránh target leakage ở huấn luyện nhưng là bắt buộc ở đánh giá tập test)\n",
        "X_ext['Price'] = y_true_ext\n",
        "\n",
        "# ── Extract features ─────────────────────────────────────────────────────────\n",
        "X_ext = extract_features(X_ext.copy())\n",
        "\n",
        "# ── Spatial density clustering on coords ──────────────────────────────────────\n",
        "X_ext['loc_cluster'] = kmeans.predict(X_ext[['Tọa độ x', 'Tọa độ y']].fillna(\n",
        "    X_ext[['Tọa độ x', 'Tọa độ y']].median()\n",
        "))\n",
        "ext_counts = X_ext['loc_cluster'].value_counts().to_dict()\n",
        "X_ext['cluster_density'] = X_ext['loc_cluster'].map(ext_counts)\n",
        "X_ext['log_cluster_density'] = np.log1p(X_ext['cluster_density'])\n",
        "\n",
        "# ── Align preprocessing transformations ────────────────────────────────────────\\n",
        "onehot_feats = [c for c in ONEHOT_COLS if c in X_ext.columns]\\n",
        "if onehot_feats:\\n",
        "    ohe_cols = []\\n",
        "    for i, col in enumerate(onehot_feats):\\n",
        "        for val in ohe.categories_[i]:\\n",
        "            ohe_cols.append(f\\"{col}_{str(val).replace(' ', '_').replace('/', '_')}\\")\\n",
        "    X_ext_ohe = pd.DataFrame(ohe.transform(X_ext[onehot_feats].fillna('MISSING')), columns=ohe_cols, index=X_ext.index)\\n",
        "else:\\n",
        "    X_ext_ohe = pd.DataFrame(index=X_ext.index)\\n",
        "\n",
        "X_ext_te = encoder.transform(X_ext[target_feats].fillna('MISSING'))\n",
        "X_ext_num = X_ext[numeric_feats].fillna(0)\n",
        "X_ext_final = pd.concat([X_ext_num, X_ext_ohe, X_ext_te], axis=1)\n",
        "\n",
        "# Predict individual models\n",
        "p_xgb_ext = np.expm1(m_xgb.predict(X_ext_final))\n",
        "p_lgb_ext = np.expm1(m_lgb.predict(X_ext_final))\n",
        "p_cat_ext = np.expm1(m_cat.predict(X_ext_final))\n",
        "\n",
        "# Predict ensemble\n",
        "if ensemble_method == 'stacking':\n",
        "    stack_ext = np.column_stack([p_xgb_ext, p_lgb_ext, p_cat_ext])\n",
        "    y_pred_ext = meta.predict(stack_ext)\n",
        "else:\n",
        "    y_pred_ext = best_w[0] * p_xgb_ext + best_w[1] * p_lgb_ext + best_w[2] * p_cat_ext\n",
        "\n",
        "# Metrics\n",
        "mape_ext = mean_absolute_percentage_error(y_true_ext, y_pred_ext)\n",
        "print(f'\\n{\"═\"*55}')\n",
        "print(f'  📊 HaNoiData External Evaluation (V12)')\n",
        "print(f'{\"═\"*55}')\n",
        "print(f'  MAPE:    {mape_ext*100:.2f}%')\n",
        "print(f'  Samples: {len(y_true_ext):,}')\n",
        "print(f'  Ensemble: {ensemble_method.upper()}')\n",
        "print(f'{\"═\"*55}')\n",
        "\n",
        "# MAPE by district\n",
        "eval_ext = X_ext[['Quận']].copy()\n",
        "eval_ext['y_true'] = y_true_ext.values\n",
        "eval_ext['y_pred'] = y_pred_ext\n",
        "mape_by_district = (\n",
        "    eval_ext.groupby('Quận')\n",
        "    .apply(lambda x: mean_absolute_percentage_error(x['y_true'], x['y_pred']) * 100)\n",
        "    .rename('MAPE (%)')\n",
        "    .round(2)\n",
        "    .sort_values()\n",
        ")\n",
        "print('\\nMAPE by District:')\n",
        "print(mape_by_district.to_string())"
      ]
    }
  ],
